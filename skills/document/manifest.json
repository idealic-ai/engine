{
  "name": "document",
  "version": "3",
  "description": "Keeps documentation in sync with code changes and project state. Triggers: \\\"update documentation\\\", \\\"patch the docs\\\", \\\"sync docs with code changes\\\", \\\"update architecture docs\\\".",
  "tier": "protocol",
  "taskType": "DOCUMENT_UPDATE",
  "templates": {
    "plan": "assets/TEMPLATE_DOCUMENTATION_PLAN.md",
    "log": "assets/TEMPLATE_DOCUMENTATION_LOG.md",
    "debrief": "assets/TEMPLATE_DOCUMENTATION.md",
    "request": "assets/TEMPLATE_DOCUMENTATION_REQUEST.md",
    "response": "assets/TEMPLATE_DOCUMENTATION_RESPONSE.md"
  },
  "phases": [
