{
  "name": "fix",
  "version": "3",
  "description": "Systematic diagnosis and repair of bugs, failures, and regressions \u2014 structured triage before action, with two walk-throughs (issues + fixes). Supports goal-based modes: General (standard investigate-fix-verify), TDD (test-first discipline), Hotfix (abbreviated emergency), Custom (user-defined lens). Triggers: \\\"fix this\\\", \\\"fix the tests\\\", \\\"investigate this failure\\\", \\\"why is this broken\\\", \\\"something isn't working right\\\", \\\"performance is degraded\\\".",
  "tier": "protocol",
  "taskType": "FIX",
  "templates": {
    "plan": "assets/TEMPLATE_FIX_PLAN.md",
    "log": "assets/TEMPLATE_FIX_LOG.md",
    "debrief": "assets/TEMPLATE_FIX.md",
    "request": "assets/TEMPLATE_FIX_REQUEST.md",
    "response": "assets/TEMPLATE_FIX_RESPONSE.md"
  },
